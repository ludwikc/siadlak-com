import Layout from "@/components/layout/Layout";
import SEO from "@/components/SEO";
import { getFunnelBySlug, getPhaseBoundaries } from "@/config/funnels";
import { useFunnelPhase } from "@/hooks/use-funnel-phase";
import FunnelCountdown from "@/components/funnel/FunnelCountdown";
import FunnelExpiredNotice from "@/components/funnel/FunnelExpiredNotice";

export default function {{PascalSlug}}Replay() {
  const funnel = getFunnelBySlug("{{slug}}")!;
  const { phase, replayDeadline } = useFunnelPhase(funnel);

  if (phase === "expired" || !funnel.replay) {
    return (
      <Layout>
        <SEO title={`${funnel.name} — nagranie`} description="Nagranie wydarzenia" noindex />
        <section className="py-20 md:py-32 bg-void min-h-screen">
          <div className="container mx-auto px-4">
            <FunnelExpiredNotice funnel={funnel} />
          </div>
        </section>
      </Layout>
    );
  }

  return (
    <Layout hideFooter>
      <SEO title={`${funnel.name} — nagranie`} description="Nagranie wydarzenia" noindex />

      <section className="py-12 md:py-20 bg-void min-h-screen">
        <div className="container mx-auto px-4 max-w-5xl text-center">
          <h1 className="text-3xl md:text-4xl font-bold text-white mb-4">
            {funnel.name} — nagranie
          </h1>

          {replayDeadline && (
            <FunnelCountdown
              target={replayDeadline}
              label="Nagranie zniknie za:"
              className="mb-8 text-white"
            />
          )}

          {funnel.replay.url ? (
            <div className="aspect-video w-full rounded-xl overflow-hidden border border-white/10 mb-8">
              <iframe
                src={funnel.replay.url}
                title={funnel.name}
                className="w-full h-full"
                allow="autoplay; encrypted-media"
                allowFullScreen
              />
            </div>
          ) : (
            <p className="text-lg text-dim mb-8">
              Nagranie pojawi się tu wkrótce — wróć za chwilę.
            </p>
          )}
        </div>
      </section>
    </Layout>
  );
}
